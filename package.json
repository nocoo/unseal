{
  "name": "unseal",
  "version": "0.1.0",
  "type": "module",
  "description": "Scan macOS /Applications for quarantined apps and batch-remove the quarantine attribute",
  "bin": {
    "unseal": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=node --outdir=dist",
    "test": "bun test tests/scanner.test.ts tests/sudo.test.ts tests/unseal.test.ts tests/prompt.test.ts && bun test tests/index.test.ts",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.11",
    "husky": "^9.1.7",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0"
  }
}
